# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=attendai
DATABASE_PASSWORD=CHANGE_THIS_STRONG_DB_PASSWORD
DATABASE_NAME=attendai

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=production

# Set to false in production — use migrations instead of auto-sync
DB_SYNCHRONIZE=false

# ── Super-admin credentials ───────────────────────────────────────────────────
# Change these before deploying. The password is also used as X-Admin-Key
# for protecting seed/admin endpoints.
ADMIN_USERNAME=sams_admin
ADMIN_PASSWORD=CHANGE_THIS_STRONG_ADMIN_PASSWORD
ADMIN_FULL_NAME=SAMS Administrator

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your exact frontend domain. Never use * in production.
# Example: https://sams.indongozi.rw
CORS_ORIGIN=https://your-frontend-domain.com

# ── Face recognition tuning ───────────────────────────────────────────────────
# Lower threshold = stricter matching (fewer false positives)
RECOGNITION_THRESHOLD=0.6
MIN_RECOGNITION_CONFIDENCE=0.5

# ── Attendance cooldown ───────────────────────────────────────────────────────
# Minimum minutes between two scans for the same person (prevents double scans)
CHECKIN_COOLDOWN_MINUTES=1
